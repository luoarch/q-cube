{
  "name": "@q3/quant-engine",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "python3 -m q3_quant_engine",
    "worker": "celery -A q3_quant_engine.celery_app worker -Q strategy --loglevel=info",
    "db:migrate": "python3 -m q3_quant_engine.migrations",
    "db:seed": "python3 -m q3_quant_engine.seeds",
    "lint": "python3 -m ruff check src",
    "typecheck": "python3 -m mypy src",
    "test": "python3 -m pytest"
  }
}
