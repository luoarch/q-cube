# App — global environment mode
NODE_ENV=development

# Web — Next.js frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API — NestJS backend
API_PORT=4000
DATABASE_URL=postgresql://127.0.0.1:5432/q3
