{
  "name": "q-cube",
  "private": true,
  "version": "0.1.0",
  "description": "Q³ — Quantity • Quality • Quant Technology",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "bootstrap:local": "bash scripts/bootstrap-local.sh",
    "db:migrate": "bash scripts/db-migrate.sh",
    "db:seed": "bash scripts/db-seed.sh",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,css}\"",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 delete q3-web q3-api q3-quant-engine q3-quant-worker q3-market-ingestion",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "pm2": "^6.0.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ],
    "overrides": {
      "@radix-ui/react-portal": ">=1.0.0"
    }
  }
}
